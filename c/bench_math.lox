fun run(limit) {
  var i = 0;
  var total = 0;
  var guard = 1;

  while (i < limit) {
    total = total + i * 3 - i / 2 + guard;

    if (total > 1000000) {
      total = total - 1000000;
      guard = guard + 1;
    } else {
      guard = guard * 2;
    }

    if (guard > 50 and total < 500000) {
      guard = 1;
    }

    i = i + 1;
  }

  return total + guard;
}

var start = clock();
var answer = run(35000000);
print clock() - start;
print answer;